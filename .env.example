# For local dev with Postgres (install Postgres or use Docker):
DATABASE_URL="postgresql://postgres:password@localhost:5432/propflow"

# For Supabase (production on Vercel) - get this from Supabase > Settings > Database:
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres"

PASSWORD="your-shared-password"
JWT_SECRET="generate-a-random-secret"

# Optional features (add when ready):
# RESEND_API_KEY="re_xxxx"
# ANTHROPIC_API_KEY="sk-ant-xxxx"
# GOOGLE_CALENDAR_CLIENT_EMAIL="xxx@xxx.iam.gserviceaccount.com"
